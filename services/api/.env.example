# =============================================================================
# @roam/api — environment variables
#
# Copy to `.env` for local dev. Never commit a real `.env*` file.
# All vars are OPTIONAL: the service boots (and `/healthz` answers) even with
# none set — required vars become hard requirements at the point of use
# (e.g., FASTMOVE_* are only enforced inside FastmoveClient).
#
# In deployed envs (Railway) secrets come from the hub per
# `agent-rules/10-secrets-via-linear.md` — never paste them into the dashboard.
# =============================================================================

# ---- Server ----------------------------------------------------------------
PORT=3001
# Surfaced on /healthz so we can confirm which build is live in each env.
# Railway typically injects this as RAILWAY_GIT_COMMIT_SHA; copy to GIT_SHA.
GIT_SHA=

# ---- Database (shared Supabase project: ravn-shared) -----------------------
# Backend-only role with search_path locked to roam_poc + roam_poc_backend.
# Pulled from hub:
#   supabase.shared.poc_roles.roam_poc_backend.connection_url
# Never expose to the browser; never use the shared service_role_key here.
DATABASE_URL=postgres://roam_poc_backend:replace@db.example:5432/postgres?sslmode=require

# ---- Fastmove supplier (世界移動) ------------------------------------------
# Source: ROA-86 Decision D1 (Fastmove API v2.0.3_20260224).
# Two independent environments — production and test each have their own
# MerchantId / DeptId / Token / wmproductId catalogue. NEVER cross them.
#   test:       https://tfmshippingsys.fastmove.com.tw
#   production: https://fmshippingsys.fastmove.com.tw
FASTMOVE_BASE_URL=https://tfmshippingsys.fastmove.com.tw
FASTMOVE_MERCHANT_ID=
FASTMOVE_DEPT_ID=
FASTMOVE_MERCHANT_KEY=

# ---- Admin API (ROA-58 manual-sync button) ---------------------------------
# Required to enable the `/admin/*` routes (supplier-plan sync trigger +
# sync log read). Unset means the routes return 503 — that's the desired
# default in any environment where the admin UI isn't deployed.
# Generate with: `openssl rand -hex 32`.
ADMIN_API_TOKEN=
