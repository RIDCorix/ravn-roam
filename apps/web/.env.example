# =============================================================================
# Roam system frontend (apps/web) — environment variables
#
# Copy to `.env.local` for local dev. Never commit a real `.env*` file.
# Next.js 16 loads `.env*` from the project root, NOT from `/src`.
# Variables prefixed `NEXT_PUBLIC_` are inlined into the client bundle at
# build time; everything else stays server-only.
#
# Secrets in deployed envs (Vercel preview / production) are sourced from the
# hub's `secrets-get.sh` per agent-rules/10-secrets-via-linear.md — NOT set
# directly in the Vercel dashboard.
# =============================================================================

# ---- Supabase (shared project: ravn-shared) --------------------------------
# Public anon key — safe to ship to the browser, scoped by Row Level Security.
# Pulled from hub: supabase.shared.url / supabase.shared.anon_key
NEXT_PUBLIC_SUPABASE_URL=https://your-shared-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-public-key

# ---- Site -------------------------------------------------------------------
# Canonical system-app origin. Distinct from landing's NEXT_PUBLIC_SITE_URL —
# this points at roam-system (admin + storefront), not roam-web (landing).
# Vercel auto-injects this as `VERCEL_URL` per deploy; override only for
# stable custom domains.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ---- Roam API (services/api on Railway) ------------------------------------
# Every admin page server-renders through `apps/web/src/lib/api.ts`, which
# calls `${ROAM_API_URL}/admin/...`. Unset → falls back to localhost:3001,
# which only works for `pnpm --filter @roam/api dev` running on the same
# machine; in Vercel that fallback fails and the admin UI shows
# "API unreachable: …".
#
# Production / preview value: the Railway public URL from
# `.ravn/project.yaml` → `infra.railway.roam_api.public_url`.
ROAM_API_URL=http://localhost:3001

# Shared-secret header sent as `x-admin-token` on the manual-sync route
# (`POST /admin/suppliers/:code/sync`). Must match `ADMIN_API_TOKEN` on the
# @roam/api side or the route returns 401 / 503. Generate with
# `openssl rand -hex 32`; store in the hub master secrets issue.
ADMIN_API_TOKEN=

# Optional. Stamped onto audit_log rows via `x-admin-user` header when the
# admin UI mutates suppliers / supplier_plans. Defaults to "admin" if unset.
# Phase 3 will replace this with a real auth identity.
ROAM_ADMIN_USER=admin

# ---- OpenAI (Lumi chat) ----------------------------------------------------
# Server-only API key for the Lumi trip assistant (`POST /api/lumi`).
# Generate at https://platform.openai.com/api-keys. Never expose to the
# browser — the route handler runs on the server and streams the response.
OPENAI_API_KEY=

# Chat model used by Lumi. Default is `gpt-4o-mini`, which is the cheapest
# chat-capable OpenAI model at the time of writing (~$0.15 / 1M input
# tokens, ~$0.60 / 1M output). Before changing, double-check the current
# pricing page (https://openai.com/api/pricing) — if a cheaper model with
# equivalent capability ships, switch over and update this comment.
# C-2 budget: system prompt ~500 tokens, max_tokens = 600 per reply.
OPENAI_MODEL=gpt-4o-mini
