# =============================================================================
# Roam marketing site — environment variables
#
# Copy to `.env.local` for local dev. Never commit a real `.env*` file.
# Next.js 16 loads `.env*` from the project root, NOT from `/src`.
# Variables prefixed `NEXT_PUBLIC_` are inlined into the client bundle at
# build time; everything else stays server-only.
#
# Secrets in deployed envs (Vercel preview / production) are sourced from the
# hub's `secrets-get.sh` per agent-rules/10-secrets-via-linear.md — NOT set
# directly in the Vercel dashboard.
# =============================================================================

# ---- Supabase (shared project: ravn-shared) --------------------------------
# Public anon key — safe to ship to the browser, scoped by Row Level Security.
# Pulled from hub: supabase.shared.url / supabase.shared.anon_key
NEXT_PUBLIC_SUPABASE_URL=https://your-shared-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-public-key

# Per-PoC Postgres connection string (role: <slug>_poc_user, search_path locked
# to the PoC's schema). Use this for any server-side direct Postgres work
# (Prisma, drizzle, raw pg). Pulled from hub:
#   supabase.shared.poc_roles.roam_poc.connection_url
# NEVER expose to the browser. NEVER use the shared service_role_key from app
# code — see agent-rules/06-shared-supabase.md.
DATABASE_URL=postgres://roam_poc_user:replace@db.example:5432/postgres?options=--search_path%3Droam_poc&sslmode=require

# ---- Site -------------------------------------------------------------------
# Canonical site origin. Used for OpenGraph URLs and absolute links.
# Vercel auto-injects this as `VERCEL_URL` per deploy; override only for
# stable custom domains.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
